PHOTONNE_TOOLS_USER=admin
PHOTONNE_TOOLS_PASS=changeme

# Rutas permitidas (deben coincidir con los HOST_PATH_* de abajo).
PHOTONNE_TOOLS_ALLOWED_ROOTS=/media/HDD,/DATA,/home,/tmp

# Volúmenes a montar (host path : mismo path en contenedor).
HOST_PATH_1=/media/HDD
HOST_PATH_2=/DATA
HOST_PATH_3=/home
HOST_PATH_4=/tmp

# Bind (127.0.0.1 = solo localhost, 0.0.0.0 = toda la LAN).
BIND_ADDR=127.0.0.1
BIND_PORT=8765

PHOTONNE_TOOLS_DB=/data-app/photonne-tools.db
PHOTONNE_TOOLS_LOGS=/data-app/logs
